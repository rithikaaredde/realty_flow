{
  "compilerOptions": {
    "target": "ES2017",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",

    "types": ["node"],                // ✅ FIXES process, __dirname, etc.
    "resolveJsonModule": true,        // ✅ needed for seed JSON files
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules"]
}